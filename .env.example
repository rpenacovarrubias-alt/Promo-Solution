# =============================================================
# Promo Solution — Variables de entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a GitHub
# =============================================================

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:contraseña@HOST:5432/promosolution?schema=promo_panel

# ── Servidor admin (Express) ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── API pública (n8n / bots / Julio) ─────────────────────────────────────────
# Genera con: openssl rand -hex 32
PUBLIC_API_KEY=ps_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sitio público Next.js ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://promosolution.com.mx
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_ADMIN_API=https://admin.promosolution.com.mx
# URL interna para SSR (Docker): si corre en Docker, usa http://admin:4000
# Si corre en local (npm run dev), déjalo en blanco (usará NEXT_PUBLIC_ADMIN_API)
ADMIN_API_URL=

# ── APIs Proveedores ──────────────────────────────────────────────────────────
# (estos se guardan en la BD — solo requeridos si se usan variables de entorno como fallback)

# 4 For Promotional
FORPROMOTIONAL_ID=22100

# Doble Vela
DOBLEVELA_CUENTA=C010535

# Innovation
INNOVATION_CUENTA=PECJ680416PZ6

# ── Email (envío de cotizaciones) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ventas@promosolution.com.mx
SMTP_PASS=                     # contraseña de app de Gmail
