generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["promo_panel"]
}

// ─── Usuarios ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(SELLER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("promo_panel")
}

enum Role {
  ADMIN
  SALES_MANAGER
  SELLER

  @@schema("promo_panel")
}

// ─── Proveedores y Catálogo ───────────────────────────────────────────────────

model Provider {
  id        String    @id @default(cuid())
  name      String
  apiUrl    String
  apiKey    String
  logo      String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@schema("promo_panel")
}

model Category {
  id              String    @id @default(cuid())
  name            String    @unique
  seoDescription  String?
  seoKeywords     String?
  utilityPercent  Decimal   @default(0) @db.Decimal(5, 2)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@schema("promo_panel")
}

model Collection {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  seoDescription String?
  seoKeywords    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@schema("promo_panel")
}

model Product {
  id          String           @id @default(cuid())
  providerId  String
  provider    Provider         @relation(fields: [providerId], references: [id])
  externalId  String
  name        String
  description String?
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])
  basePrice   Decimal          @db.Decimal(10, 2)
  isActive    Boolean          @default(true)
  images      ProductImage[]
  colors      ProductColor[]
  variants    ProductVariant[]
  quoteItems  QuoteItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([providerId, externalId])
  @@schema("promo_panel")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean @default(false)

  @@schema("promo_panel")
}

model ProductColor {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String
  hex       String?

  @@schema("promo_panel")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  material  String?
  size      String?
  minQty    Int     @default(1)

  @@schema("promo_panel")
}

// ─── Servicios ────────────────────────────────────────────────────────────────

model Service {
  id          String      @id @default(cuid())
  name        String
  type        ServiceType
  unitPrice   Decimal     @db.Decimal(10, 2)
  description String?
  isActive    Boolean     @default(true)
  quoteItems  QuoteItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@schema("promo_panel")
}

enum ServiceType {
  ESTAMPADO
  BORDADO
  GRABADO
  SUBLIMACION
  OTRO

  @@schema("promo_panel")
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  company       String?
  markupPercent Decimal  @default(30) @db.Decimal(5, 2)
  quotes        Quote[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@schema("promo_panel")
}

// ─── Configuración ───────────────────────────────────────────────────────────

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@schema("promo_panel")
}

// ─── Cotizaciones ─────────────────────────────────────────────────────────────

model Quote {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id])
  status    QuoteStatus @default(DRAFT)
  channels  Channel[]
  subtotal  Decimal     @db.Decimal(10, 2)
  iva       Decimal     @db.Decimal(10, 2)
  total     Decimal     @db.Decimal(10, 2)
  notes     String?
  items     QuoteItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@schema("promo_panel")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED

  @@schema("promo_panel")
}

enum Channel {
  EMAIL
  WHATSAPP
  TELEGRAM

  @@schema("promo_panel")
}

model QuoteItem {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  markup    Decimal  @db.Decimal(5, 2)
  subtotal  Decimal  @db.Decimal(10, 2)

  @@schema("promo_panel")
}
